{
  "name": "dungeon-buddies",
  "version": "1.0.0",
  "private": true,
  "description": "Original three-player real-time dungeon card game web app.",
  "type": "module",
  "scripts": {
  "start": "node server/index.js",
  "build:client": "cd client && npm install && npm run build"
}
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/index.js",
    "client:dev": "vite --host 0.0.0.0 --config client/vite.config.js",
    "build": "vite build --config client/vite.config.js",
    "start": "NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "express": "latest",
    "nanoid": "latest",
    "nodemon": "latest",
    "react": "latest",
    "react-dom": "latest",
    "socket.io": "latest",
    "socket.io-client": "latest",
    "vite": "latest"
  },
  "engines": {
    "node": ">=20"
  }
}
